AZURE_OPENAI_API_KEY="your_azure_openai_api_key_here"
AZURE_OPENAI_ENDPOINT="your_azure_openai_endpoint_here"
AZURE_OPENAI_API_VERSION=

AZURE_GPT4O_DEPLOYMENT=gpt-4o
AZURE_GPT4O_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

EMBEDDING_DIMENSIONS=3072
CHROMA_PERSIST_DIR=./data/indexes/chroma
CHUNK_SIZES=4096, 1024, 512
MAX_HIERARCHICAL_LEVELS=3
CHUNK_OVERLAP=32
TOP_K_RETRIEVAL=6
ENABLE_AUTO_MERGE=false
MAX_CONTEXT_TOKENS=8000
LOG_LEVEL=INFO

# Langgraph 
REDIS_URL: str | None = None
LANGGRAPH_PERSISTENCE: bool = True
CONFIDENCE_HIGH: float = 0.75
CONFIDENCE_LOW: float = 0.40